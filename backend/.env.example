# HTTP server
PORT=3001

# OpenAI (commentary) — use a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_COMMENTARY_MODEL=gpt-4o-mini

# ElevenLabs (TTS) — key from https://elevenlabs.io/
ELEVENLABS_API_KEY=

# MQTT (TLS)
# Set either MQTT_BROKER (full URL) or MQTT_HOST + MQTT_PORT_TLS
# MQTT_BROKER=mqtts://your-broker.example.com:8883
MQTT_HOST=
MQTT_PORT_TLS=8883
MQTT_USERNAME=
MQTT_PASSWORD=

# Device provisioning (must match firmware)
PROVISION_TOKEN=
